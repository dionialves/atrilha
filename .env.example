# Variaveis de ambiente para desenvolvimento local do atrilha.
# Copie este arquivo para .env e preencha os valores reais.
# .env esta no .gitignore — nao commite credenciais.

# --- OAuth Google (US-002) ---
# Credenciais obtidas em https://console.cloud.google.com
# 1. Criar projeto.
# 2. OAuth consent screen (External, scopes: openid, email, profile).
# 3. Credenciais > Criar credencial > OAuth client ID > Web application.
# 4. Origens autorizadas: http://localhost:8084
# 5. URIs de redirecionamento: http://localhost:8084/login/oauth2/code/google
GOOGLE_OAUTH_CLIENT_ID=seu-client-id-aqui.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=seu-client-secret-aqui

# --- Base URL (opcional em dev, ja default no application-dev) ---
# BASE_URL=http://localhost:8084
# MAIL_FROM=ola@atrilha.local
