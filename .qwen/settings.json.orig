{
  "$schema": "https://raw.githubusercontent.com/QwenLM/qwen-code/main/packages/cli/src/config/settingsSchema.json",
  "env": {
    "LMSTUDIO_API_KEY": "lm-studio"
  },
  "modelProviders": {
    "openai": [
      {
        "id": "qwen3.6-35b-a3b-ud-mlx",
        "name": "Qwen3.6 35B A3B UD MLX (Codificador)",
        "envKey": "LMSTUDIO_API_KEY",
        "baseUrl": "http://localhost:1234/v1",
        "generationConfig": {
          "timeout": 1800000,
          "maxRetries": 3,
          "contextWindowSize": 262144,
          "samplingParams": {
            "temperature": 0.2,
            "top_p": 0.9
          }
        }
      },
      {
        "id": "qwen3.6-35b-a3b-mlx",
        "name": "Qwen3.6 35B A3B MLX (Arquiteto + Revisor)",
        "envKey": "LMSTUDIO_API_KEY",
        "baseUrl": "http://localhost:1234/v1",
        "generationConfig": {
          "timeout": 1800000,
          "maxRetries": 3,
          "contextWindowSize": 262144,
          "samplingParams": {
            "temperature": 0.1,
            "top_p": 0.9
          }
        }
      }
    ]
  },
  "security": {
    "auth": {
      "selectedType": "openai"
    }
  },
  "model": {
    "name": "qwen3.6-35b-a3b-mlx"
  },
  "tools": {
    "approvalMode": "yolo"
  },
  "$version": 4,
  "permissions": {
    "allow": [
      "Agent(codificador)",
      "Bash(bash *)",
      "Bash(./mvnw *)",
      "Bash(git rm *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(ls *)",
      "Bash(gh *)",
      "Bash(do *)",
      "Bash(then *)",
      "Bash(else *)",
      "Bash(fi)",
      "Bash(done)",
      "Bash(file *)",
      "Bash(grep *)",
      "Bash(xxd *)",
      "Bash(readlink *)",
      "Bash(stat *)"
    ]
  }
}