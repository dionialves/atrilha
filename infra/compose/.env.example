# .env.example — variaveis de ambiente para docker-compose.prod.yml
#
# IMPORTANTE: Este arquivo e apenas um template. O arquivo .env real com as
# credenciais de producao fica em /opt/zayt/atrilha/.env na VPS e NUNCA deve ser
# commitado no repositorio (ver .gitignore: infra/compose/.env).
#
# Como usar:
#   cp infra/compose/.env.example /opt/zayt/atrilha/.env
#   # Edite /opt/zayt/atrilha/.env com os valores reais antes de subir os containers.

# Banco de dados PostgreSQL
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Tag da imagem Docker a ser executada (ex: latest, v1.0.0, sha-abc1234)
APP_TAG=

# Diretorio no HOST onde os uploads (avatares, etc.) sao armazenados.
# E montado em /var/atrilha/media dentro do container. Use um caminho
# absoluto, acessivel para backup. Exemplo: /opt/zayt/atrilha/media
HOST_MEDIA_DIR=/opt/zayt/atrilha/media

# E-mail transacional (SMTP do provider — Brevo/Mailgun/SES/Postmark/SendGrid).
# MAIL_HOST/USERNAME/PASSWORD vem do painel do provider escolhido.
# MAIL_PORT padrao 587 (STARTTLS); use 465 apenas se o provider exigir SSL.
# MAIL_FROM precisa ser um endereco no dominio com SPF+DKIM publicados.
# BASE_URL e a URL publica da aplicacao — usada para montar o link de
# verificacao no corpo do email (ex.: https://atrilha.seudominio.com).
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
BASE_URL=

# OAuth Google (US-002 — cadastro/login social)
# Credenciais obtidas em https://console.cloud.google.com:
#   1. Criar projeto.
#   2. APIs & Services > OAuth consent screen — User type: External, scopes: openid, email, profile.
#      Para liberar contas externas, clicar PUBLISH APP (senao, so test users autorizados entram).
#   3. APIs & Services > Credentials > + CREATE CREDENTIALS > OAuth client ID > Web application.
#   4. Authorized JavaScript origins:   ${BASE_URL acima}
#   5. Authorized redirect URIs:        ${BASE_URL}/login/oauth2/code/google
#      (path tem que bater EXATAMENTE com o handler do Spring Security)
# Sem essas duas variaveis o boot do profile prod falha na inicializacao.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
